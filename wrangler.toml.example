# 记账客户管理系统 - wrangler.toml.example
# 复制为 wrangler.toml 并填入真实值后使用

name = "kehuguanli"
compatibility_date = "2025-01-01"

# D1 数据库
[[d1_databases]]
binding = "DB"
database_name = "kehuguanli-db"
database_id = "your-database-id-here"

# 环境变量（生产环境请在 Cloudflare Dashboard 中设置）
[vars]
# JWT_SECRET - 签名密钥，必须设置（生产环境使用强随机字符串）
# 建议: openssl rand -base64 32
JWT_SECRET = "dev-secret-change-in-production"

# [env.production.vars]
# JWT_SECRET = "your-production-secret"